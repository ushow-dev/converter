        {
          "expr": "rate(converter_p2p_bytes_total{source=\"http\"}[5m])",
          "legendFormat": "HTTP bytes/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Segments by Source",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
