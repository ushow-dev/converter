#!/usr/bin/env bash
#
# commit-msg hook: validates Conventional Commits format
# Installed via: git config core.hooksPath .githooks
#

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Skip merge commits, fixup!, squash!
if echo "$COMMIT_MSG" | grep -qE "^(Merge |fixup! |squash! )"; then
  exit 0
fi

# Allowed types
TYPES="feat|fix|docs|style|refactor|perf|test|chore|ci|build|revert"

# Allowed scopes for this project
SCOPES="api|worker|frontend|docker|docs|deps|auth|queue|player|subtitles|ffmpeg|db|config"

# Pattern: type(scope): description
# - type required
# - scope optional
# - description: non-empty, no trailing period, no UPPERCASE start
PATTERN="^($TYPES)(\(($SCOPES)\))?: .{1,100}$"

# Check format
if ! echo "$COMMIT_MSG" | head -1 | grep -qE "$PATTERN"; then
  echo ""
  echo "  ✗ Неверный формат commit message."
  echo ""
  echo "  Ожидается: <type>(<scope>): <описание>"
  echo ""
  echo "  Типы:   feat fix docs style refactor perf test chore ci build revert"
  echo "  Скоупы: api worker frontend docker docs deps auth queue player subtitles ffmpeg db config"
  echo ""
  echo "  Примеры:"
  echo "    feat(api): add rate limiting middleware"
  echo "    fix(worker): handle ffmpeg timeout correctly"
  echo "    docs(contracts): update ConvertPayload schema"
  echo "    chore(deps): bump pgx to v5.7.3"
  echo "    ci: add github actions workflow"
  echo ""
  echo "  Ваш message: \"$(echo "$COMMIT_MSG" | head -1)\""
  echo ""
  exit 1
fi

# Check description doesn't start with uppercase (style: lowercase after colon)
DESCRIPTION=$(echo "$COMMIT_MSG" | head -1 | sed 's/^[^:]*: //')
FIRST_CHAR=$(echo "$DESCRIPTION" | cut -c1)
if echo "$FIRST_CHAR" | grep -q "[A-Z]"; then
  echo ""
  echo "  ✗ Описание должно начинаться со строчной буквы."
  echo "  Ваше: \"$DESCRIPTION\""
  echo "  Верно: \"$(echo "$DESCRIPTION" | sed 's/./\l&/')\""
  echo ""
  exit 1
fi

# Check description doesn't end with period
if echo "$DESCRIPTION" | grep -q "\.$"; then
  echo ""
  echo "  ✗ Описание не должно заканчиваться точкой."
  echo ""
  exit 1
fi

exit 0
