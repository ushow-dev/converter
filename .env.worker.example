# ─────────────────────────────────────────────────────────────────
# Worker Server — переменные окружения
# Используется с: docker compose -f docker-compose.worker.yml up -d
# Скопируй в .env и заполни значения.
# ─────────────────────────────────────────────────────────────────

# ── Подключение к API-серверу ─────────────────────────────────────
# PostgreSQL и Redis находятся на API-сервере.
# Для безопасности используй WireGuard или expose только на приватный IP.
DATABASE_URL=postgres://app:changeme_postgres_password@API_SERVER_IP:5432/mediadb?sslmode=disable
REDIS_URL=redis://API_SERVER_IP:6379

# ── Host / LinuxServer.io container user ─────────────────────────
PUID=1000
PGID=1000
TZ=Europe/Moscow

# ── qBittorrent ───────────────────────────────────────────────────
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_USER=admin
QBITTORRENT_PASSWORD=changeme_qbit_password

# ── Worker ────────────────────────────────────────────────────────
WORKER_HEALTH_PORT=8001
DOWNLOAD_CONCURRENCY=2
# Рекомендация: количество ядер CPU / 2
CONVERT_CONCURRENCY=2
# 0 = ffmpeg сам выбирает количество потоков
FFMPEG_THREADS=0

# Локальный путь для временных файлов (загрузки, конвертация).
# Нужен быстрый диск (SSD).
MEDIA_PATH=/opt/media

# ── Внешние API ───────────────────────────────────────────────────
TMDB_API_KEY=changeme_tmdb_api_key
OPENSUBTITLES_API_KEY=changeme_opensubtitles_api_key
SUBTITLE_LANGUAGES=en,bn,hi

# ── Transfer: origin storage (45.134.174.84) ─────────────────────
# После конвертации worker заливает HLS на storage-сервер через rclone/SFTP.
# SSH-ключ должен лежать в ./secrets/mediarw_rclone
RCLONE_CONFIG_MYREMOTE_TYPE=sftp
RCLONE_CONFIG_MYREMOTE_HOST=45.134.174.84
RCLONE_CONFIG_MYREMOTE_USER=mediarw
RCLONE_CONFIG_MYREMOTE_KEY_FILE=/secrets/mediarw_rclone
RCLONE_REMOTE=myremote
RCLONE_REMOTE_PATH=/storage
TRANSFER_CONCURRENCY=1

# ── Ingest: scanner-сервер (213.111.156.183) ─────────────────────
# SSH-ключ должен лежать в ./secrets/scanner_rclone
RCLONE_CONFIG_SCANREMOTE_TYPE=sftp
RCLONE_CONFIG_SCANREMOTE_HOST=213.111.156.183
RCLONE_CONFIG_SCANREMOTE_USER=root
RCLONE_CONFIG_SCANREMOTE_KEY_FILE=/secrets/scanner_rclone
INGEST_SOURCE_REMOTE=scanremote
INGEST_SOURCE_BASE_PATH=/incoming
INGEST_SERVICE_TOKEN=changeme_ingest_service_token
INGEST_CONCURRENCY=3
INGEST_CLAIM_TTL_SEC=7200
INGEST_MAX_ATTEMPTS=3
SCANNER_API_URL=http://213.111.156.183:8080

# ── Образы ────────────────────────────────────────────────────────
APP_IMAGE_TAG=latest
