# ─────────────────────────────────────────────────────────────────
# API Server — переменные окружения
# Используется с: docker compose -f docker-compose.api.yml up -d
# Скопируй в .env и заполни значения.
# ─────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=mediadb

# ── Core API ──────────────────────────────────────────────────────
API_PORT=8000
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
PLAYER_API_KEY=changeme_player_api_key
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password

# Публичный URL откуда nginx/CDN раздаёт медиафайлы.
# После настройки CDN Edge — адрес edge-сервера.
MEDIA_BASE_URL=https://media.example.com
MEDIA_SIGNING_KEY=changeme_media_signing_key
MEDIA_SIGNING_TTL=2m

# Локальный путь для временного хранения загружаемых файлов и субтитров.
# В целевой архитектуре нужно решить хранение субтитров (см. docs/architecture/target-production-architecture.md)
MEDIA_PATH=./media

# ── Prowlarr — работает на worker-сервере ─────────────────────────
# Формат: http://{WORKER_SERVER_IP}:9696
PROWLARR_BASE_URL=http://WORKER_SERVER_IP:9696
PROWLARR_API_KEY=changeme_prowlarr_api_key

# ── Внешние API ───────────────────────────────────────────────────
TMDB_API_KEY=changeme_tmdb_api_key
OPENSUBTITLES_API_KEY=changeme_opensubtitles_api_key
SUBTITLE_LANGUAGES=en,bn,hi

# ── Scanner (опционально) ─────────────────────────────────────────
# URL scanner HTTP API для проксирования в admin panel.
# Формат: http://{SCANNER_SERVER_IP}:8080
SCANNER_API_URL=http://SCANNER_SERVER_IP:8080
INGEST_SERVICE_TOKEN=changeme_ingest_service_token

# ── Frontend ──────────────────────────────────────────────────────
FRONTEND_PORT=3000
# URL плеера — после настройки CDN Edge будет адрес edge-сервера.
PLAYER_URL=https://player.example.com

# ── Образы ────────────────────────────────────────────────────────
APP_IMAGE_TAG=latest
