# ─────────────────────────────────────────────────────────────────
# Media Processing Admin System — Environment Variables
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Host / LinuxServer.io container user ─────────────────────────
# Run `id` on the host to get UID/GID matching your media files.
PUID=1000
PGID=1000
TZ=Europe/Moscow

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme_postgres_password
POSTGRES_DB=mediadb

# ── Redis ─────────────────────────────────────────────────────────
# No password required by default; add requirepass in redis command
# if the deployment needs auth.

# ── Prowlarr ──────────────────────────────────────────────────────
# API key is generated by Prowlarr on first run.
# Obtain from Prowlarr → Settings → General → API Key.
PROWLARR_API_KEY=changeme_prowlarr_api_key

# ── qBittorrent ───────────────────────────────────────────────────
# Web UI port inside the container (exposed only on app_net).
QBITTORRENT_WEBUI_PORT=8080
# Default credentials for linuxserver/qbittorrent; change after first run.
QBITTORRENT_USER=admin
QBITTORRENT_PASSWORD=changeme_qbit_password

# ── Core API ──────────────────────────────────────────────────────
API_PORT=8000
# HS256 JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
# Service-to-service key for Player API consumers
PLAYER_API_KEY=changeme_player_api_key
# Public base URL where nginx serves media files (HLS/posters).
# Example: https://media.example.com
# Empty value keeps relative links like /media/converted/<id>/master.m3u8
MEDIA_BASE_URL=
# Secret for nginx secure_link token validation.
# Generate with: openssl rand -hex 32
# Must match `set $hls_signing_secret` in ptrack.ink.conf.
MEDIA_SIGNING_KEY=changeme_media_signing_key
# Signed URL lifetime (Go duration format), e.g. 30s, 2m.
MEDIA_SIGNING_TTL=2m

# Admin credentials for Phase 2 login endpoint.
# Option A (recommended for production): set pre-hashed bcrypt password.
#   Generate with: htpasswd -bnBC 10 '' 'yourpassword' | tr -d ':\n'
# ADMIN_PASSWORD_HASH=$2y$10$...
# Option B (dev convenience): set plaintext — hashed at startup, never stored.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme_admin_password

# ── Worker ────────────────────────────────────────────────────────
WORKER_HEALTH_PORT=8001

# ── Frontend ──────────────────────────────────────────────────────
# Host port that maps to the Next.js container port 3000.
FRONTEND_PORT=3000
# Server-side URL of the API used by Next.js rewrites to proxy /api/* requests.
# NOT exposed to the browser; client code uses relative /api/... paths.
# Set directly in docker-compose.yml (http://api:8000). Override here only if needed.
# API_URL=http://api:8000

# ── Application image tags ────────────────────────────────────────
# Tag used for api / worker / frontend images.
# Override individual images with API_IMAGE / WORKER_IMAGE / FRONTEND_IMAGE
# if they live in separate registries.
APP_IMAGE_TAG=latest
# API_IMAGE=app/api
# WORKER_IMAGE=app/worker
# FRONTEND_IMAGE=app/frontend

# ── nginx (optional) ──────────────────────────────────────────────
# Uncomment when nginx service is enabled in docker-compose.yml.
# NGINX_HTTP_PORT=80
