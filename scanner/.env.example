# Host paths (bind-mounted into container by docker-compose)
INCOMING_HOST_DIR=/mnt/storage/incoming
LIBRARY_HOST_DIR=/mnt/storage/library

# Container-internal paths (used by the scanner process)
INCOMING_DIR=/incoming
LIBRARY_DIR=/library

# Scanner HTTP API
SCANNER_API_PORT=8080
SERVICE_TOKEN=changeme

# TMDB (https://www.themoviedb.org/settings/api)
TMDB_API_KEY=changeme

# Database
DATABASE_URL=postgresql://scanner:scanner@postgres:5432/scanner

# Tuning (seconds)
SCAN_INTERVAL_SEC=30
STABILITY_SEC=30
