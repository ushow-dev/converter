# Paths (bind-mounted into container)
INCOMING_DIR=/mnt/storage/incoming
LIBRARY_DIR=/mnt/storage/library

# Converter API
CONVERTER_API_URL=http://converter-server:8000
CONVERTER_SERVICE_TOKEN=changeme

