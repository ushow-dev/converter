# URL of the core API server (no trailing slash)
API_URL=http://localhost:8000

# X-Player-Key value sent in every request to /api/player/movie
# Must match PLAYER_API_KEY configured in the API service
PLAYER_KEY=your-player-key

# VAST ad tag URL for pre-roll / mid-roll ads.
# Leave empty to disable ads entirely.
NEXT_PUBLIC_VAST_TAG=https://proton9.engine.adglare.net/?320596439
